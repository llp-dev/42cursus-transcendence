# ==================== Database ====================
DB_HOST=postgres
DB_PORT=5432
DB_USER=app
DB_PASSWORD=app
DB_NAME=app_db

# ==================== API Configuration ====================
API_PORT=8000
GIN_MODE=debug

# ==================== JWT ====================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

REDIS_HOST=redis
REDIS_PORT=6379
# ==================== Environment ====================
ENVIRONMENT=development

# ==================== Optional: CORS ====================
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:80

# ==================== Logging ====================
LOG_LEVEL=debug